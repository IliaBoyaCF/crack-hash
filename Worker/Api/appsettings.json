{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Manager": {
    "Address": "http://manager:8080"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "RabbitMQTaskQueue": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "admin",
    "Password": "admin123",
    "VirtualHost": "/",
    "ExchangeName": "tasks.direct",
    "QueueName": "worker_tasks",
    "RoutingKey": "task.schedule",
    "Durable": true,
    "PrefetchCount": 1
  },
  "RabbitMQResponseQueue": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "admin",
    "Password": "admin123",
    "VirtualHost": "/",
    "ExchangeName": "response.direct",
    "QueueName": "worker_response",
    "RoutingKey": "task.response",
    "Durable": true,
    "PrefetchCount": 1
  }
}
